{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/og/site.tsx": {
      "maxDuration": 15
    },
    "api/og/artist.tsx": {
      "maxDuration": 15
    },
    "api/share/artist.ts": {
      "maxDuration": 10
    },
    "api/share/feature.ts": {
      "maxDuration": 10
    },
    "api/link-preview.ts": {
      "maxDuration": 15
    },
    "api/thumbnail.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
