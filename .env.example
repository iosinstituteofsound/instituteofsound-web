# instituteofsound-web — copy to .env
# cp .env.example .env

# Dev: leave VITE_API_BASE_URL unset — Vite proxies /api/* → instituteofsound-api :4000
# Production: set VITE_API_BASE_URL=https://your-api-host.example.com

VITE_API_BASE_URL=
VITE_SITE_URL=http://localhost:5173
VITE_APP_NAME=Institute of Sound

# Socket.io realtime (dev: Vite proxies /socket.io OR set direct API URL below)
VITE_WS_ENABLED=true
# Recommended local dev — bypass flaky Vite ws proxy:
VITE_WS_URL=http://127.0.0.1:4000
