# ============================================
# Institute of Sound — Environment Variables
# ============================================
# Copy:  cp .env.example .env
# Fill real values, then:  npm run dev
# ============================================

# ---------- Supabase ----------
# Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# ---------- API v1 (server only — Vercel + local .env, NOT VITE_) ----------
# Same project URL and keys as above; service role never goes in the browser.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Route wired modules through /api/v1/* (required in production)
VITE_USE_V1_API=true

# Daily artist page purge cron (Vercel → Settings → Environment Variables)
# Generate: openssl rand -hex 32
CRON_SECRET=

# Production site (email confirmation links — NOT localhost)
# Vercel: add same value in Project → Settings → Environment Variables
VITE_SITE_URL=https://instituteofsound.in
# OG share cards: /og/site-og.jpg (homepage) + /api/og/artist?slug=… — set VITE_SITE_URL on Vercel

# ---------- Cloudinary ----------
# Dashboard: https://console.cloudinary.com
# Browser: cloud name + preset name only (VITE_*)
# Server: API key + secret for signed uploads (never VITE_)

VITE_CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME_HERE
VITE_CLOUDINARY_UPLOAD_PRESET=ios_signed

# Server-only (Vercel + local .env — NOT committed)
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME_HERE
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
CLOUDINARY_UPLOAD_PRESET=ios_signed

# ---------- Catalog import (server only — Vercel env, NOT VITE_) ----------
# Spotify: https://developer.spotify.com/dashboard → Create app → Client ID + Secret
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Optional market for top tracks (default IN)
# SPOTIFY_MARKET=IN

# YouTube: Google Cloud Console → YouTube Data API v3 → API key
YOUTUBE_API_KEY=

# SoundCloud (optional — public resolve works without custom id in most cases)
# SOUNDCLOUD_CLIENT_ID=

# ---------- Link previews (server only — Vercel env, NOT VITE_) ----------
# Optional: Microlink Pro key for bot-protected retail sites (Guitar Center, etc.)
# https://microlink.io — add to Vercel → Settings → Environment Variables
# MICROLINK_API_KEY=
