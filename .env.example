# instituteofsound-web — copy to .env
# cp .env.example .env

# ---------- Site & API URLs ----------
# Dev overrides: cp .env.local.example .env.local
#   VITE_USE_V1_API=true
#   VITE_SITE_URL=http://localhost:5173
#   (leave VITE_API_BASE_URL unset — Vite proxies /api/* → instituteofsound-api :4000)
#
# Production build: cp .env.production.example .env.production
#   VITE_SITE_URL=https://www.instituteofsound.in
#   VITE_API_BASE_URL=https://your-api-host.example.com
#   VITE_USE_V1_API=true

# ---------- Cloudinary (browser uploads) ----------
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=ios_unsigned

# ---------- YouTube (artist channel import in browser) ----------
VITE_YOUTUBE_API_KEY=
